---
const tools = [
  {
    id: "adblock-video",
    name: "AdBlock.video",
    tagline: "Ad-Free YouTube Viewing",
    description: "Watch and subscribe to YouTube videos without ads. Browser plugin, web app, or Bluesky integration—enjoy uninterrupted viewing however you prefer.",
    features: ["Follow favorite content", "Watch Ad Free", "Web app install", "Bluesky integration", "Browser Plugins/Ext", "Local storage & backup"],
    url: "https://adblock.video",
    logo: "/ad-block-logo.svg"
  },
  {
    id: "clipslide",
    name: "ClipSlide.app",
    tagline: "Shareable Video Playlists",
    description: "Build shareable video playlists with drag-and-drop controls, post directly to Bluesky. Create stunning slideshows from your photo libraries and YouTube videos.",
    features: ["Easy to use Library", "Drag-and-drop editor", "Quiz & Trivia Features", "Video Music Challenges", "Custom Preview Images", "Local storage & backup"],
    url: "https://clipslide.app",
    logo: "/ClipSlide-Logo.svg"
  },
  {
    id: "finalword",
    name: "FinalWord.app",
    tagline: "Post Scheduler for Bluesky",
    description: "Compose and schedule posts for automatic publishing. Create dead man switches for posts that will publish after your passing—leave a lasting legacy.",
    features: ["Adv Post Composer", "Scheduled posting", "Dead man switch posts", "Bluesky integration", "Settings management", "Custom Preview Images"],
    url: "https://finalword.app",
    logo: "/FinalWord-logo.svg"
  },
  {
    id: "skypost",
    name: "SkyPost.app",
    tagline: "Advanced Bluesky Client",
    description: "Post and browse Bluesky with superpowers. An alternate client with editable posts, scheduled posting, and advanced features beyond the standard app.",
    features: ["Editable posts", "Scheduled posts", "Advanced filtering", "Squads", "Tag Manager", "Custom Preview Images"],
    url: "https://skypost.app",
    logo: "/SkyPost-logo.svg"
  }
];
---

<div class="tools-section" style="padding:0 2vw;">
  <!-- Products Grid -->
  <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
    {tools.map((tool) => (
      <div class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-8 transition hover:border-blue-300 hover:shadow-lg dark:border-slate-800 dark:bg-slate-900 dark:hover:border-blue-700">
        <div class="mb-6 flex justify-center">
          <a 
            href={tool.url}
            class="mt-auto inline-flex items-center justify-center px-4 py-2 font-semibold text-slate-900 dark:text-white"
          >
            <img src={tool.logo} alt={tool.name} class="h-28 object-contain" />
          </a>
        </div>
        <h3 class="mb-2 text-xl font-bold text-slate-900 dark:text-white">
          {tool.name}
        </h3>
        <p class="mb-4 text-sm font-semibold text-blue-600 dark:text-blue-400">
          {tool.tagline}
        </p>
        <p class="mb-6 flex-grow text-slate-600 dark:text-slate-300">
          {tool.description}
        </p>
        
        <ul class="mb-6 space-y-2">
          {tool.features.map((feature) => (
            <li class="flex items-center text-sm text-slate-600 dark:text-slate-400">
              <span class="mr-2 text-blue-600 dark:text-blue-400">✓</span>
              {feature}
            </li>
          ))}
        </ul>

        <a 
          href={tool.url}
          class="mt-auto inline-flex items-center justify-center rounded-lg bg-slate-100 px-4 py-2 font-semibold text-slate-900 transition hover:bg-slate-200 dark:bg-slate-800 dark:text-white dark:hover:bg-slate-700"
        >
          Visit {tool.name}
          <span class="ml-2">→</span>
        </a>
      </div>
    ))}
  </div>

